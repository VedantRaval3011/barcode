# TCP listener
TCP_HOST=0.0.0.0
TCP_PORT=9100

# Packet format from the Keyence device: ASCII or HEX
DATA_FORMAT=ASCII

# Unique identifier for this device/station
DEVICE_ID=keyence-01

# Next.js API endpoint
API_URL=http://localhost:3000/api/scans

# Must match API_KEY in the Next.js .env.local
API_KEY=your-secret-key-here

# SQLite file used as offline buffer
BUFFER_DB_PATH=buffer.db

# Seconds to wait for a packet before checking the stop flag
CONNECTION_TIMEOUT=2.0

# Seconds between offline-buffer flush attempts
FLUSH_INTERVAL=10

# Optional metadata attached to every event
LOCATION=warehouse-a
PRODUCTION_LINE=line-1
